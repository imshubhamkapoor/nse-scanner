{
  "python.defaultInterpreterPath": "${workspaceFolder}/venv/bin/python",
  "python.terminal.activateEnvironment": true,
  "files.exclude": {
    "**/__pycache__": true,
    "**/*.pyc": true,
    "**/venv": true,
    "**/.pytest_cache": true,
    "**/.egg-info": true
  },
  "files.watcherExclude": {
    "**/venv/**": true,
    "**/__pycache__/**": true,
    "**/output/**": true,
    "**/.pytest_cache/**": true,
    "**/.egg-info/**": true,
    "**/node_modules/**": true
  },
  "search.exclude": {
    "venv": true,
    "output": true
  }
}
